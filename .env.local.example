# =============================================================
# .env.local テンプレート
# =============================================================
#
# このファイルをコピーして `.env.local` を作成し、各値を埋める。
#   cp .env.local.example .env.local
#
# 値は Vercel Dashboard から取得する。`vercel env pull` は Sensitive
# 環境変数を空文字で返すため使えない（AGENTS.md「ローカル .env.local
# の復旧手順」参照）。
#
# 1. https://vercel.com/dtsukoshi-hues-projects/mocal/settings/environment-variables
# 2. 各変数を「Show value」で表示してコピー
# 3. 下の `=""` の中に貼り付け
#
# `.env.local` は .gitignore 済み。コミット禁止。
# =============================================================

# ---- 必須（lib/env.ts の requireEnv() がチェック）----

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# セッション
SESSION_SECRET=""

# Stripe（Connect — Destination Charges）
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# WebPush（VAPID）
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT=""

# 公開 URL
NEXT_PUBLIC_APP_URL=""

# ---- オプション（無くても起動可、機能が無効化される）----

# Upstash Redis（rate limit 分散対応。無ければ in-memory フォールバック）
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend（メール送信。未設定なら lib/email.ts が no-op）
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Stripe Connect Onboarding（店舗の Connect アカウント連携。未設定なら onboarding 機能無効）
STRIPE_CLIENT_ID=""

# cron 保護トークン（/api/cron/* の認可。未設定だと cron エンドポイントが公開状態）
CRON_SECRET=""

# 顧客注文ステータスページのポーリング間隔（ミリ秒、最小 1000）
# 未設定なら 10000 (10 秒)。deploy 直後の transition 期間に 5000 へ短縮など。
NEXT_PUBLIC_ORDER_POLLING_MS=""

# anonymous user cleanup cron (#34) を有効化するか
# "1" のときのみ実削除を実行。それ以外は dry-run と同等（候補数のみ返却）。
# pilot phase は default off (空文字) で OK。本格運用前に "1" にする。
CLEANUP_ANON_USERS_ENABLED=""
