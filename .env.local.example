# ============================================================
# mocal 環境変数テンプレート
# .env.local にコピーして実値を設定してください
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- 管理画面セッション ---
# SESSION_SECRET は openssl rand -hex 32 などで生成
SESSION_SECRET=replace-with-32-byte-random-hex
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_STORE_ID=00000000-0000-0000-0000-000000000000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- WebPush（VAPID）---
# 鍵は npx web-push generate-vapid-keys で生成
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
